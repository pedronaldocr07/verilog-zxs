# Kalshi API (required for authenticated calls)
KALSHI_API_KEY=

# Private key: use either file path or PEM string
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Set to true for demo environment (demo-api.kalshi.co)
KALSHI_DEMO=false

# Optional: override base URL (defaults to prod or demo based on KALSHI_DEMO)
# KALSHI_BASE_PATH=https://api.elections.kalshi.com/trade-api/v2

# --- Bot (Bitcoin up/down) ---
# KALSHI_BOT_SIDE=yes          # yes = up, no = down
# KALSHI_BOT_PRICE_CENTS=50    # limit price 1-99
# KALSHI_BOT_CONTRACTS=1
# KALSHI_BOT_MAX_MARKETS=15
# KALSHI_BOT_DRY_RUN=true      # no real orders
